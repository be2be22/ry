# Admin credentials (optional - auto-generated on first boot if missing, logged once)
ADMIN_USER=admin
ADMIN_PASSWORD=

# JWT secret (optional - auto-generated on first boot if missing, logged once)
JWT_SECRET=

# HTTP port for the web panel (Railway injects $PORT automatically; only set for local dev)
PORT=3000

# Internal Xray VLESS/gRPC/REALITY listen port (separate from PORT)
# Enable Railway TCP Proxy on this port to get a public host:port.
XRAY_PORT=8443

# Local port for Xray Stats API (internal only, NOT exposed to internet)
XRAY_API_PORT=10085

# Where to store SQLite db, xray-config.json, logs, REALITY keypair (Railway Volume should mount here)
DATA_DIR=/data

# Path to the Xray binary (downloaded in Dockerfile)
XRAY_BIN=/usr/local/bin/xray

# Where the built frontend lives
STATIC_DIR=/app/client/dist

# Node env
NODE_ENV=production
