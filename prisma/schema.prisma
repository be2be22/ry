// Prisma schema for the CyberX VPN Panel
// اسکیمای دیتابیس پنل مدیریت VPN

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ادمین‌های پنل — چند ادمین با سطوح دسترسی مختلف
model Admin {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          String   @default("ADMIN") // SUPER_ADMIN | ADMIN
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs AuditLog[]
}

// کاربران VPN — هر کاربر ۸ کانفیگ با پروتکل‌های مختلف دریافت می‌کند
model VpnUser {
  id              String   @id @default(cuid())
  uuid            String   @unique // Xray client UUID
  username        String   @unique
  subToken        String   @unique // subscription token (UUID-like)
  notes           String?
  tags            String?  // comma-separated tags

  // سهمیه و انقضا
  dataLimitBytes  BigInt   @default(0) // 0 = unlimited
  usedBytes       BigInt   @default(0)
  expireAt        DateTime?
  enabled         Boolean  @default(true)
  suspended       Boolean  @default(false)

  // محدودیت اتصال
  maxDevices      Int      @default(3)

  // محدودیت IP/کشور (اختیاری)
  allowedIps      String?  // comma separated CIDRs/IPs

  planId          String?
  plan            Plan?    @relation(fields: [planId], references: [id])

  // آمار اتصال زنده
  onlineDevices   Int      @default(0)
  lastSeenAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trafficRecords  TrafficRecord[]
}

// اینباندهای Xray — پیکربندی پروتکل‌ها
model Inbound {
  id           String   @id @default(cuid())
  tag          String   @unique
  protocol     String   // vless | vmess | trojan
  port         Int
  network      String   // ws | grpc | xhttp | tcp
  security     String   // tls | reality | none
  path         String?  // for ws/xhttp
  serviceName  String?  // for grpc
  sni          String?
  enabled      Boolean  @default(true)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// لاگ ممیزی — هر اکشن مهم
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id])
  action    String   // LOGIN, LOGIN_FAIL, USER_CREATE, USER_DELETE, USER_TOGGLE, XRAY_RESTART, ...
  target    String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

// تنظیمات عمومی پنل — جفت کلید/مقدار
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// پلن‌ها/بسته‌های پیش‌فرض
model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  dataLimitGb   Float    @default(0) // 0 = unlimited
  durationDays  Int      @default(30)
  maxDevices    Int      @default(3)
  price         Float    @default(0)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users VpnUser[]
}

// رکورد ترافیک دوره‌ای برای نمودارها
model TrafficRecord {
  id        String   @id @default(cuid())
  userId    String
  user      VpnUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  upBytes   BigInt
  downBytes BigInt
  createdAt DateTime @default(now())
}

// بکاپ‌ها
model Backup {
  id        String   @id @default(cuid())
  filename  String
  size      BigInt
  createdAt DateTime @default(now())
}
