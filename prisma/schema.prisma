// Prisma schema for FastApiCloud WS Config Management Panel
// Local Xray mode: Xray runs as a subprocess on the same host as the panel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  email     String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id          String   @id @default(cuid())
  name        String
  host        String   // domain used in share links (e.g. fastapicloud.com)
  port        Int      @default(443) // public-facing port for share links
  protocol    String   @default("ws")
  remark      String?
  location    String?
  isActive    Boolean  @default(true)
  configs     Config[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Config {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("vmess") // vmess | vless | trojan
  uuid            String
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  path            String   @default("/")
  host            String?
  sni             String?
  tls             String   @default("tls") // tls | none
  security        String   @default("auto")
  encryption      String   @default("none") // for vless
  alterId         Int      @default(0) // for vmess
  network         String   @default("ws")
  port            Int      @default(443)
  flow            String?
  status          String   @default("active") // active | disabled | expired
  uploadBytes     BigInt   @default(0)
  downloadBytes   BigInt   @default(0)
  totalUsageBytes BigInt   @default(0)
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  assignedUserId  String?
  assignedUser    User?    @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  // Local Xray state
  xrayActive      Boolean  @default(false) // whether this user is currently in the running config
  xrayAddedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([serverId])
  @@index([assignedUserId])
  @@index([status])
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String?
  phone       String?
  status      String   @default("active") // active | suspended | expired
  dataLimit   BigInt   @default(0) // in bytes, 0 = unlimited
  dataUsed    BigInt   @default(0)
  expireDays  Int      @default(30)
  expiresAt   DateTime?
  configs     Config[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  detail    String?
  adminId   String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
